# =============================================================================
# 環境変数サンプル（このファイルをコピーして .env を作成してください）
# 実際の値はコミットしないこと。一覧は lib/env.ts のスキーマが正です。
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth / セッション
# -----------------------------------------------------------------------------
# 本番・next build では必須。開発のみなら未設定時は auth.config.ts のフォールバックあり。
# 互換: NEXTAUTH_SECRET
# 生成例（PowerShell）: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
AUTH_SECRET=

# -----------------------------------------------------------------------------
# ログイン（メール／パスワード）
# -----------------------------------------------------------------------------
# ユーザーは DynamoDB の USER 行（passwordHashB64 / saltB64）で認証されます。
# （※ AUTH_USERS_JSON 等の JSON 環境変数は現状コードでは未使用）

# -----------------------------------------------------------------------------
# DynamoDB（職員 staffId ↔ ログイン主体の紐づけ）
# -----------------------------------------------------------------------------
# パーティションキー pk (String) のみ・オンデマンド
# 作成: web/scripts/create-dynamodb-user-staff-table.ps1
DYNAMODB_USER_STAFF_TABLE=
DYNAMODB_REGION=

# 移行用のみ: Dynamo に行が無いときの挙動（complete-profile 等で参照）。安定後は外すか空のまま。
AUTH_STAFF_LINK_FALLBACK_GOOGLE=

# -----------------------------------------------------------------------------
# Google OAuth（現状 auth からは未使用）
# -----------------------------------------------------------------------------
# auth.ts は Credentials プロバイダのみ。Google ログインを再度有効にする場合に設定。
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GOOGLE_ALLOWED_HOSTED_DOMAINS=

# -----------------------------------------------------------------------------
# 権限・マスタ照合
# -----------------------------------------------------------------------------
# 管理者（マスタ氏名と一致。カンマ区切り。空白差は照合時に無視）
ADMIN_NAMES=
# 幹部（MVBe 選出除外など）。1件以上あるときはこの一覧を優先。空ならマスタ列ベース。
EXECUTIVE_STAFF_NAMES=

# -----------------------------------------------------------------------------
# Google スプレッドシート（マスタ・回答）
# -----------------------------------------------------------------------------
# 実運用ではマスタ ID + サービスアカウント JSON が事実上必須（sheetsConfigured）
GOOGLE_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# 回答ブック（未設定時のフォールバック: GOOGLE_RESPONSES_SPREADSHEET_ID → GOOGLE_SPREADSHEET_ID）
GOOGLE_RESPONSES_SPREADSHEET_ID=
GOOGLE_RESPONSES_SOREINE_SPREADSHEET_ID=
GOOGLE_RESPONSES_MVBE_SPREADSHEET_ID=

# タブ名（実シート名に合わせる。同一キーを2行に書かない）
SHEET_ENROLLMENT=
# Code.gs 等と同一の回答シート名にすること（既定: フォームの回答 1）
SHEET_RESPONSES_SOREINE=
# MVBe は `GOOGLE_RESPONSES_MVBE_SPREADSHEET_ID` ブックのこのタブへ追記（13列・末尾 MVBE_V2）
SHEET_RESPONSES_MVBE=
# 移行用（任意）: 同一ブック内に残している旧 MVBe タブ。読み取りのみマージ（追記しない）
SHEET_RESPONSES_MVBE_LEGACY=
# レガシー名のみスキーマに残存。アプリからの追記は未使用。
# SHEET_REGISTRATION=rogin

# マスタを当月以外のシートに固定するデバッグ用（任意）
# SHEET_MASTER_DEBUG=

# マスタキャッシュ秒数（5〜3600、既定 120）
MASTER_CACHE_SECONDS=120

# -----------------------------------------------------------------------------
# Discord（ソレイイネ通知・メンバー解決）
# -----------------------------------------------------------------------------
DISCORD_SOREINE_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
SHEET_MEMBER_DISCORD_MAP=

# -----------------------------------------------------------------------------
# MVBe 未提出リマインド
# -----------------------------------------------------------------------------
# 公開 URL（リマインド文面のフォームリンク。未設定時は Vercel では VERCEL_URL を利用）
NEXT_PUBLIC_APP_ORIGIN=
DISCORD_MVBE_REMINDER_WEBHOOK_URL=
# リマインド投稿先スレッド ID（任意・未設定なら Webhook の親チャンネル）。管理画面からの送信時は画面入力が優先されます。
# DISCORD_MVBE_REMINDER_THREAD_ID=
# Cron: POST /api/cron/mvbe-reminder  Authorization: Bearer <secret>
MVBE_REMINDER_CRON_SECRET=
# 一時確認: 1 または true で、下記メッセージ（未指定時は test）のみメンションなしで 1 通送信。本番では未設定のまま。
# MVBE_REMINDER_DISCORD_TEST_ONLY=1
# MVBE_REMINDER_DISCORD_TEST_MESSAGE=test
# シート読めないときの文案（プレースホルダは lib/mvbe-reminder 参照）
MVBE_REMINDER_TEMPLATE=
# マスタ GOOGLE_SPREADSHEET_ID 内のテンプレシート
SHEET_MVBE_REMINDER_TEMPLATE=
SHEET_MVBE_REMINDER_TEMPLATE_CELL=

# MVBe 部署係数上限（既定 3）
MVBE_DEPT_WEIGHT_MAX=3

# -----------------------------------------------------------------------------
# 強みレポート（Gemini）
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=
# 未設定だとページを開くたび AI が走りやすい
DYNAMODB_STRENGTHS_SNAPSHOT_TABLE=
# Cron: POST /api/cron/strengths-snapshot  Authorization: Bearer <secret>
STRENGTHS_CRON_SECRET=

# -----------------------------------------------------------------------------
# UI・その他
# -----------------------------------------------------------------------------
NEXT_PUBLIC_LEVELA_LOGO_URL=
# 開発用モックマスタ（本番では通常 false / 空）
NEXT_PUBLIC_USE_MOCK_MASTER=

# スキーマのみ（現状アプリで未参照。外部フォームリンク用に温存）
# NEXT_PUBLIC_GOOGLE_FORM_REGISTER_URL=
# NEXT_PUBLIC_GOOGLE_FORM_RETIRE_URL=

# -----------------------------------------------------------------------------
# メール SMTP（将来用・現状アプリ未使用 lib/env.ts 注記）
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=
# EMAIL_FROM=
