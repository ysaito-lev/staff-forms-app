# NextAuth（本番・`next build` では必須。開発だけなら未設定でも起動用の既定値を使います）
# 互換: NEXTAUTH_SECRET でも可
# 生成例（PowerShell）: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
AUTH_SECRET=
# AccessDenied の切り分け（1 のときのみ。問題が分かったら外すこと）
# - console に記録するほか、Cookie と middleware で `/login?reason=コード` が付き画面でも表示（OAuth では URL 直接返却が効かないため）。
# AUTH_SIGNIN_DEBUG=1
# 「AccessDenied の原因がマスタ氏名不一致か」を試すときだけ（1/true）。問題が分かったら削除すること。
# AUTH_SIGNIN_SKIP_STAFF_MATCH=

# ログインユーザ（JSON 配列）。本番ではパスワードを安全な方式に置き換えてください。
# 例: [{"email":"user@example.com","password":"********","staffId":"スタッフID"}]
AUTH_USERS_JSON=

# 管理者（マスタの氏名と一致。カンマ区切りで複数指定。姓・名の空白の有無は無視して照合）
# 例: ADMIN_NAMES=山田 太郎,佐藤 花子
# 開発で admin@local.test を管理者にする場合は、次の名前を含める: 管理者デモ（開発）
ADMIN_NAMES=

# 幹部（MVBe 選出除外など isExecutive）。カンマ区切り・マスタの氏名と照合（空白差は無視）
# 1件以上あるときはこの一覧のみが正。未設定・空ならマスタの「幹部」列＋幹部相当部署の推定
# 例: EXECUTIVE_STAFF_NAMES=山田 太郎,佐藤 花子
EXECUTIVE_STAFF_NAMES=

# UI: ロゴのフォールバック URL（基本は public/levela-logo.png を使用。ファイルが無い・読めないときのみ参照）
# NEXT_PUBLIC_LEVELA_LOGO_URL=https://levela.co.jp/wp-content/uploads/2025/12/header-logo%20after.png

# Google スプレッドシート
# マスタ（社員名簿・在籍等）
GOOGLE_SPREADSHEET_ID=
# 回答保存先。未指定なら上記と同じIDに追記
GOOGLE_RESPONSES_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
# 在籍管理タブ名（A:氏名、C:在籍状況 — 退職は「退職済み」）
SHEET_ENROLLMENT=在籍管理マスタ
# 回答シート名（同じく回答用スプレッドシート内）
SHEET_RESPONSES_SOREINE=ソレイイネ
SHEET_RESPONSES_MVBE=MVBe
# ログイン申請の追記先タブ（回答用スプレッドシート内。列: 登録日時, 氏名, staffId, メール, パスワード）
SHEET_REGISTRATION=rogin
# マスタ当月シートに任意の「メール」「ワークスペースメール」列がある場合、ログイン Gmail と突合して職員IDを解決できる（Google 表示名のみだと読みが異なるときに有効）
# （列は実マスタのレイアウトに合わせて追加してください。コードは自動検出します）

# パスワード再設定メール（SMTP）。未設定だと /api/password-reset は 503 になります。
# SMTP_SECURE=1 は 465 番など SSL/TLS 接続時
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=
# EMAIL_FROM="統合フォーム <noreply@example.com>"
# マスタを特定シートに固定する場合（未設定＝JST 当月の「yyyy年m月」シート）
# SHEET_MASTER_DEBUG=
